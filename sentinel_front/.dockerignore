# =============================================================================
# FRONTEND .dockerignore — Sentinel Frontend (Vite + React + TypeScript)
# =============================================================================
# Contexto de build: ./sentinel_front
# Ahorro estimado: ~180 MB (node_modules) + ~5 MB (otros)

# ── Dependencies (180+ MB — el mayor ahorro) ────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
.next/

# ── Git ──────────────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── IDE / Editor ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── OS junk ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Env files ────────────────────────────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env*.local

# ── Testing ──────────────────────────────────────────────────────────────
coverage/
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
cypress/
playwright-report/
test-results/

# ── Logs ─────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── Cache ────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.npm/
.yarn/
*.tsbuildinfo

# ── TypeScript compiled output ───────────────────────────────────────────
*.tsbuildinfo

# ── Storybook ────────────────────────────────────────────────────────────
storybook-static/

# ── Misc ─────────────────────────────────────────────────────────────────
tmp/
temp/
*.tgz
*.bak
.pnp.*
.yarn-integrity

# ── Docker files (no se copian a la imagen) ──────────────────────────────
Dockerfile
.dockerignore
